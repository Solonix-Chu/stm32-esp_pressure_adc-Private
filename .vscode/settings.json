{
  "cmake.generator": "Ninja",
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.configureOnOpen": false,
  "cmake.sourceDirectory": "${workspaceFolder}",
  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
  "stm32.toolchainPath": "/usr/bin",
  "stm32.gdbPath": "/usr/bin/gdb-multiarch",
  "stm32.buildDir": "${workspaceFolder}/build",
  "stm32.elfPath": "${workspaceFolder}/build/firmware.elf",
  "stm32.binPath": "${workspaceFolder}/build/firmware.bin",
  "stm32.device": "STM32F103C8",
  "stm32.interface": "swd",
  "stm32.flashAddress": "0x08000000",
  "stm32.svdFile": "",
  "stm32.openocdPath": "/usr/bin/openocd",
  "stm32.openocd.stlinkInterface": "interface/stlink.cfg",
  "stm32.openocd.daplinkInterface": "interface/cmsis-dap.cfg",
  "stm32.openocd.target": "target/stm32f1x.cfg",
  "stm32.pyocd.path": "pyocd",
  "stm32.pyocd.target": "stm32f103c8",
  "stm32.jlink.gdbServerPath": "JLinkGDBServerCLExe",
  "stm32.jlink.commanderPath": "JLinkExe",
  "stm32.jlink.device": "STM32F103C8",
  "stm32.jlink.speed": "4000",
  "stm32.cubeprog.cliPath": "STM32_Programmer_CLI",
  "stm32.cubeprog.port": "SWD"
}
