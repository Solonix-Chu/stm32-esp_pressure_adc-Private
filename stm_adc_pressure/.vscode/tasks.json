{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: configure Debug",
      "type": "process",
      "command": "cmake",
      "args": [
        "--preset",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: build Debug",
      "type": "process",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: configure Debug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CMake: rebuild Debug",
      "type": "process",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "Debug",
        "--clean-first"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: configure Debug",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "OpenOCD: flash Debug (J-Link SWD)",
      "type": "process",
      "command": "openocd",
      "args": [
        "-f",
        ".vscode/openocd-jlink-swd.cfg",
        "-c",
        "program ${workspaceFolder}/build/Debug/stm_adc_pressure.elf verify reset exit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: build Debug",
      "problemMatcher": []
    }
  ]
}
